---
import Base from "../../layouts/Base.astro"

const posts = [
  {
    href: "/blog/mqtt-siwe-design",
    date: "2026-06-20",
    title: "Designing MQTT Auth with EIP-191 Signatures",
    tags: ["MQTT", "EIP-191", "TypeScript", "Workshop 07"],
    excerpt:
      "Why broker-level username/password auth is fragile for IoT — and how time-bounded cryptographic signatures solve replay attacks at the transport layer.",
  },
  {
    href: "/blog/nanomq-vs-mosquitto",
    date: "2026-06-18",
    title: "NanoMQ vs Mosquitto: Architecture Deep Dive",
    tags: ["MQTT", "Research", "NanoMQ", "Benchmarks"],
    excerpt:
      "Source-verified history and architecture comparison. NanoMQ's actor model (255K msg/s) vs Mosquitto's epoll event loop (81K msg/s), and why EMQ targets automotive.",
  },
]
---

<Base title="Blog — Sombo No.88" description="Technical writing from Sombo No.88 on MQTT, blockchain, and systems design.">
  <div style="padding: 120px 24px 80px; max-width: 760px; margin: 0 auto;">
    <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 12px;">
      <span class="gradient-text">Blog</span>
    </h1>
    <p style="color: #64748b; margin-bottom: 60px;">
      Technical writing from my learning process — MQTT, blockchain, and systems.
    </p>

    <div style="display: flex; flex-direction: column; gap: 24px;">
      {posts.map((post) => (
        <a
          href={post.href}
          class="card-glass"
          style="padding: 28px; text-decoration: none; display: block; transition: border-color 0.2s;"
          onmouseenter="this.style.borderColor='rgba(139,92,246,0.5)'"
          onmouseleave="this.style.borderColor='rgba(139,92,246,0.2)'"
        >
          <div style="font-size: 0.75rem; color: #64748b; margin-bottom: 10px; font-family: monospace;">
            {post.date}
          </div>
          <h2 style="font-size: 1.2rem; font-weight: 700; color: #e2e8f0; margin-bottom: 12px;">
            {post.title}
          </h2>
          <p style="color: #94a3b8; font-size: 0.875rem; line-height: 1.7; margin-bottom: 20px;">
            {post.excerpt}
          </p>
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            {post.tags.map((tag) => (
              <span style="font-size: 0.7rem; padding: 3px 10px; border-radius: 100px; background: rgba(139,92,246,0.12); color: #a78bfa; border: 1px solid rgba(139,92,246,0.25);">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
