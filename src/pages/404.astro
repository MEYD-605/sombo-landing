---
import Base from "../layouts/Base.astro"
---

<Base title="404 — Not Found | Sombo No.88">
  <div class="min-h-screen flex items-center justify-center p-6 text-center">
    <div class="space-y-6">
      <div class="text-6xl">🤖</div>
      <h1 class="text-6xl font-display font-semibold tracking-tight text-champagne leading-none">
        404
        <span class="block text-2xl text-gold font-sans mt-2">ไม่พบหน้านี้</span>
      </h1>
      <p class="text-sm text-text-muted max-w-xs mx-auto">
        Page not found. Sombo checked the index database — it's not here.
        <span class="block text-xs text-text-warm mt-1 font-normal">ไม่พบหน้าที่ค้นหา สารบบบันทึกข้อมูลว่างเปล่าสำหรับ URL นี้</span>
      </p>
      <div class="pt-4">
        <a href="/" class="px-6 py-2.5 bg-gold text-[oklch(7%_0.006_95)] hover:bg-gold-rich font-sans font-medium rounded-xs transition-colors cursor-pointer text-sm">
          Back Home / กลับหน้าหลัก
        </a>
      </div>
    </div>
  </div>
</Base>
