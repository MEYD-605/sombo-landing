---
import Base from "../layouts/Base.astro"
---

<Base title="404 — Not Found | Sombo No.88">
  <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; text-align: center;">
    <div>
      <div style="font-size: 6rem; margin-bottom: 16px;">🤖</div>
      <h1 style="font-size: 3rem; font-weight: 800; margin-bottom: 16px;">
        <span class="gradient-text">404</span>
      </h1>
      <p style="color: #94a3b8; margin-bottom: 32px; font-size: 1.1rem;">
        Page not found. Sombo checked — it's not here.
      </p>
      <a
        href="/"
        style="background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white; padding: 12px 28px; border-radius: 10px; font-weight: 600; text-decoration: none;"
      >
        Back Home
      </a>
    </div>
  </div>
</Base>
